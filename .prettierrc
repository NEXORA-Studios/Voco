{
    "endOfLine": "crlf",
    "semi": true,
    "singleQuote": false,
    "tabWidth": 4,
    "trailingComma": "es5",
    "bracketSameLine": true,
    "printWidth": 128,
    "plugins": ["prettier-plugin-tailwindcss"],
    "tailwindStylesheet": "packages/ui/src/styles/globals.css",
    "tailwindFunctions": ["cn", "cva"],
    "overrides": [
        {
            "files": "**/index.ts",
            "options": {
                "printWidth": 2147483647
            }
        }
    ]
}
