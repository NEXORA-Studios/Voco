{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Voco",
    "version": "0.1.0",
    "identifier": "tech.nexora-studios.voco.desktop",
    "build": {
        "frontendDist": "../web",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Voco",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
    }
}
